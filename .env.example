# ================================================================
# 🔒 ENVIRONMENT VARIABLES - OPTISAAS SECURE TEMPLATE
# ================================================================
# IMPORTANT: NEVER commit actual .env file to Git!
# Copy this to .env and fill with your values
# ================================================================

# ================================================================
# NODE ENVIRONMENT
# ================================================================
NODE_ENV=production
PORT=3000

# ================================================================
# CORS - WHITELIST SPECIFIC ORIGINS
# ================================================================
# ✅ PRODUCTION: Set to your actual frontend domain(s)
# ✅ MULTIPLE: Comma-separated list
# ❌ NEVER: use wildcard (*)
CORS_ORIGIN=https://yourdomain.com,https://app.yourdomain.com

# ================================================================
# DATABASE - PostgreSQL
# ================================================================
DATABASE_URL=postgresql://user:SECURE_PASSWORD@localhost:5432/optisaas?schema=public

# ================================================================
# JWT AUTHENTICATION
# ================================================================
# ✅ Generate with: openssl rand -base64 32
JWT_SECRET=YOUR_SECURE_JWT_SECRET_HERE_CHANGE_ME
JWT_EXPIRATION=24h

# ================================================================
# MINIO - FILE STORAGE
# ================================================================
# ✅ PRODUCTION: Use strong credentials
# ✅ Generate keys with: openssl rand -base64 32
# ❌ NEVER: Use 'minioadmin' or other defaults

MINIO_ENDPOINT=minio.yourdomain.com
MINIO_ACCESS_KEY=YOUR_STRONG_ACCESS_KEY_HERE
MINIO_SECRET_KEY=YOUR_STRONG_SECRET_KEY_HERE
MINIO_BUCKET=optisaas-uploads
MINIO_USE_SSL=true
UPLOAD_DIR=./uploads

# ================================================================
# EMAIL SERVICE - SMTP
# ================================================================
# ✅ PRODUCTION: Use production email service
# ✅ Gmail: Create App Password (not regular password)
# ✅ SendGrid/Mailgun: Use API key

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here
SMTP_FROM=noreply@yourdomain.com
SMTP_SECURE=true

# ================================================================
# LOGGING
# ================================================================
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10485760  # 10MB in bytes
LOG_MAX_FILES=10

# ================================================================
# RATE LIMITING
# ================================================================
# Requests per minute
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# ================================================================
# SECURITY HEADERS
# ================================================================
# Content Security Policy (CSP)
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: https:

# CORS Headers
ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# ================================================================
# OPTIONAL: REDIS (for caching/sessions)
# ================================================================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password

# ================================================================
# OPTIONAL: SENTRY (Error tracking)
# ================================================================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# SENTRY_ENVIRONMENT=production

# ================================================================
# OPTIONAL: AWS SECRETS MANAGER
# ================================================================
# AWS_REGION=eu-west-1
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_SECRET_NAME=optisaas/prod/secrets

# ================================================================
# IMPORTANT NOTES
# ================================================================
# 1. NEVER commit this file to Git (add to .gitignore)
# 2. NEVER share sensitive values
# 3. ALWAYS use strong passwords (32+ chars, mixed case, symbols)
# 4. ALWAYS use HTTPS in production
# 5. ALWAYS use environment variables for secrets (not hardcoded)
# 6. ROTATE secrets regularly (quarterly minimum)
# 7. Use secrets vault (AWS Secrets, Vault, etc) in production
# 8. Monitor for exposed secrets (git-secrets, truffleHog, etc)

# ================================================================
# SECURITY CHECKLIST
# ================================================================
# [ ] All secrets are strong (32+ chars)
# [ ] No secrets in code
# [ ] CORS_ORIGIN is specific (not wildcard)
# [ ] MINIO credentials are unique
# [ ] JWT_SECRET is unique and strong
# [ ] SMTP uses secure authentication
# [ ] SSL/TLS enabled for all connections
# [ ] .env file in .gitignore
# [ ] Environment vars set in hosting provider
# [ ] Secrets rotated every 90 days
# [ ] Access logs monitored
# [ ] Failed login attempts tracked
