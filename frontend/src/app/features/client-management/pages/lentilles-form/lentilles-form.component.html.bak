<div class="fiche-container">
    <!-- Header -->
    <div class="header">
        <div class="client-info">
            <div class="avatar-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                    <path
                        d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" />
                </svg>
            </div>
            <div class="client-details">
                <h2>{{ clientDisplayName }}</h2>
                <p *ngIf="client">
                    <span class="opacity-75 uppercase text-xs font-bold">{{ client.typeClient }}</span>
                    <ng-container *ngIf="client.telephone"> • 📞 {{ client.telephone }}</ng-container>
                    <ng-container *ngIf="client.ville"> • 📍 {{ client.ville }}</ng-container>
                </p>
                <p *ngIf="!client" class="text-gray-400 italic">Chargement du client...</p>
            </div>
        </div>
        <div class="header-actions">
            <!-- Always: Retour Dossier Client -->
            <button type="button" class="btn-secondary" (click)="goBack()">
                <mat-icon>arrow_back</mat-icon> Retour Dossier Client
            </button>
            <!-- New Mode: Annuler Creation -->
            <button type="button" class="btn-secondary" (click)="goBack()"
                *ngIf="isEditMode && (!ficheId || ficheId === 'new')">
                Annuler
            </button>
            <!-- Edit Mode: Annuler Modification -->
            <button type="button" class="btn-secondary" (click)="toggleEditMode()"
                *ngIf="isEditMode && ficheId && ficheId !== 'new'">
                Annuler modification
            </button>
            <!-- View Mode: Modifier -->
            <button type="button" class="btn-primary" (click)="toggleEditMode()"
                *ngIf="!isEditMode && ficheId && ficheId !== 'new'">
                <mat-icon>edit</mat-icon> Modifier
            </button>
            <!-- Edit Mode: Enregistrer / Mettre à jour -->
            <button type="button" class="btn-primary" (click)="onSubmit()" [disabled]="ficheForm.invalid || loading"
                *ngIf="isEditMode">
                <mat-icon>save</mat-icon> {{ (ficheId && ficheId !== 'new') ? 'Mettre à jour' : 'Enregistrer' }}
            </button>
        </div>
    </div>

    <form [formGroup]="ficheForm">
        <div class="tabs-wrapper">
            <mat-tab-group [(selectedIndex)]="activeTab" (selectedTabChange)="onTabChange($event)" animationDuration="0ms" class="custom-tabs">

            <!-- ONGLET 1: ORDONNANCE -->
            <mat-tab>
                <ng-template mat-tab-label>
                    <mat-icon class="tab-icon">description</mat-icon>
                    Ordonnance
                </ng-template>

                <div class="tab-content">
                    <div formGroupName="ordonnance">

                        <!-- Info Prescription -->
                        <mat-card class="section-card mb-4">
                            <mat-card-header class="flex justify-between items-center mb-4 px-4 pt-4">
                                <mat-card-title>Détails Ordonnance</mat-card-title>
                                <div class="flex gap-2" *ngIf="isEditMode">
                                    <button type="button" mat-raised-button color="primary" (click)="openFileUpload()">
                                        <mat-icon>upload_file</mat-icon>
                                        Importer
                                    </button>
                                    <button type="button" mat-raised-button color="accent" (click)="openCamera()">
                                        <mat-icon>photo_camera</mat-icon>
                                        Photo
                                    </button>
                                </div>
                            </mat-card-header>

                            <!-- Loading Overlay for OCR -->
                            <div class="ocr-loading" *ngIf="isProcessingOcr">
                                <mat-spinner diameter="40"></mat-spinner>
                                <span>Analyse de l'ordonnance en cours...</span>
                            </div>

                            <input #fileInput type="file" accept="image/*,application/pdf" multiple class="hidden"
                                (change)="onFilesSelected($event)">

                            <!-- Files List -->
                            <div class="px-4 mb-4" *ngIf="prescriptionFiles.length > 0">
                                <div class="files-grid">
                                    <div *ngFor="let file of prescriptionFiles; let i = index" class="file-chip">
                                        <mat-icon class="file-icon">
                                            {{ file.type.startsWith('image/') ? 'image' : 'picture_as_pdf' }}
                                        </mat-icon>
                                        <span class="file-name" (click)="viewFile(file)">{{ file.name }}</span>
                                        <button mat-icon-button class="mini-btn-delete" (click)="deleteFile(i)"
                                            *ngIf="isEditMode">
                                            <mat-icon>close</mat-icon>
                                        </button>
                                    </div>
                                </div>
                            </div>

                            <mat-card-content class="grid-3">
                                <mat-form-field appearance="outline">
                                    <mat-label>Date de prescription</mat-label>
                                    <input matInput [matDatepicker]="picker" formControlName="datePrescription">
                                    <mat-datepicker-toggle matIconSuffix [for]="picker"></mat-datepicker-toggle>
                                    <mat-datepicker #picker></mat-datepicker>
                                </mat-form-field>
                                <mat-form-field appearance="outline">
                                    <mat-label>Prescripteur</mat-label>
                                    <input matInput formControlName="prescripteur" placeholder="Dr. Ophtalmologue">
                                    <mat-icon matSuffix>person_medical</mat-icon>
                                </mat-form-field>
                                <mat-form-field appearance="outline">
                                    <mat-label>Date de contrôle</mat-label>
                                    <input matInput [matDatepicker]="pickerControleAdapt"
                                        formControlName="dateControle">
                                    <mat-datepicker-toggle matIconSuffix
                                        [for]="pickerControleAdapt"></mat-datepicker-toggle>
                                    <mat-datepicker #pickerControleAdapt></mat-datepicker>
                                </mat-form-field>
                            </mat-card-content>
                        </mat-card>

                        <div class="eyes-container">
                            <!-- OD -->
                            <mat-card class="eye-card od-card" formGroupName="od">
                                <div class="eye-header">
                                    <span class="eye-badge">OD</span>
                                    <h3>Œil Droit</h3>
                                </div>
                                <mat-card-content>
                                    <div class="grid-3">
                                        <mat-form-field appearance="outline" class="dense-field">
                                            <mat-label>Sphère</mat-label>
                                            <input matInput formControlName="sphere" placeholder="+0.00">
                                        </mat-form-field>
                                        <mat-form-field appearance="outline" class="dense-field">
                                            <mat-label>Cylindre</mat-label>
                                            <input matInput formControlName="cylindre" placeholder="-0.00">
                                        </mat-form-field>
                                        <mat-form-field appearance="outline" class="dense-field">
                                            <mat-label>Axe</mat-label>
                                            <input matInput formControlName="axe" placeholder="0°">
                                        </mat-form-field>
                                    </div>
                                    <div class="grid-4">
                                        <mat-form-field appearance="outline" class="dense-field">
                                            <mat-label>Addition</mat-label>
                                            <input matInput formControlName="addition" placeholder="+0.00">
                                        </mat-form-field>
                                        <mat-form-field appearance="outline" class="dense-field">
                                            <mat-label>AC.VIS</mat-label>
                                            <input matInput formControlName="acuiteVisuelle" placeholder="10/10">
                                        </mat-form-field>
                                        <mat-form-field appearance="outline" class="dense-field highlight-field">
                                            <mat-label>H (K1)</mat-label>
                                            <input matInput formControlName="k1" placeholder="7.80">
                                        </mat-form-field>
                                        <mat-form-field appearance="outline" class="dense-field highlight-field">
                                            <mat-label>V (K2)</mat-label>
                                            <input matInput formControlName="k2" placeholder="7.90">
                                        </mat-form-field>
                                    </div>
                                </mat-card-content>
                            </mat-card>

                            <!-- OG -->
                            <mat-card class="eye-card og-card" formGroupName="og">
                                <div class="eye-header">
                                    <span class="eye-badge">OG</span>
                                    <h3>Œil Gauche</h3>
                                </div>
                                <mat-card-content>
                                    <div class="grid-3">
                                        <mat-form-field appearance="outline" class="dense-field">
                                            <mat-label>Sphère</mat-label>
                                            <input matInput formControlName="sphere" placeholder="+0.00">
                                        </mat-form-field>
                                        <mat-form-field appearance="outline" class="dense-field">
                                            <mat-label>Cylindre</mat-label>
                                            <input matInput formControlName="cylindre" placeholder="-0.00">
                                        </mat-form-field>
                                        <mat-form-field appearance="outline" class="dense-field">
                                            <mat-label>Axe</mat-label>
                                            <input matInput formControlName="axe" placeholder="0°">
                                        </mat-form-field>
                                    </div>
                                    <div class="grid-4">
                                        <mat-form-field appearance="outline" class="dense-field">
                                            <mat-label>Addition</mat-label>
                                            <input matInput formControlName="addition" placeholder="+0.00">
                                        </mat-form-field>
                                        <mat-form-field appearance="outline" class="dense-field">
                                            <mat-label>AC.VIS</mat-label>
                                            <input matInput formControlName="acuiteVisuelle" placeholder="10/10">
                                        </mat-form-field>
                                        <mat-form-field appearance="outline" class="dense-field highlight-field">
                                            <mat-label>H (K1)</mat-label>
                                            <input matInput formControlName="k1" placeholder="7.80">
                                        </mat-form-field>
                                        <mat-form-field appearance="outline" class="dense-field highlight-field">
                                            <mat-label>V (K2)</mat-label>
                                            <input matInput formControlName="k2" placeholder="7.90">
                                        </mat-form-field>
                                    </div>
                                </mat-card-content>
                            </mat-card>
                        </div>
                        <!-- End of eyes-container -->
                    </div> <!-- End of ordonnance -->
                </div> <!-- End of tab-content -->
            </mat-tab>

            <!-- ONGLET 2: SÉLECTION LENTILLES -->
            <mat-tab>
                <ng-template mat-tab-label>
                    <mat-icon class="tab-icon">shopping_bag</mat-icon>
                    Sélection Lentilles
                </ng-template>

                <div class="tab-content" formGroupName="lentilles">
                    <!-- Type & Usage -->
                    <mat-card class="section-card mb-4">
                        <mat-card-content>
                            <div class="grid-3 align-center">
                                <mat-form-field appearance="outline">
                                    <mat-label>Type de lentille</mat-label>
                                    <mat-select formControlName="type">
                                        <mat-option *ngFor="let type of lensTypes" [value]="type">{{ type
                                            }}</mat-option>
                                    </mat-select>
                                </mat-form-field>
                                <mat-form-field appearance="outline">
                                    <mat-label>Usage</mat-label>
                                    <mat-select formControlName="usage">
                                        <mat-option *ngFor="let usage of lensUsages" [value]="usage">{{ usage
                                            }}</mat-option>
                                    </mat-select>
                                </mat-form-field>
                                <mat-checkbox formControlName="diffLentilles" color="primary">
                                    Lentilles différentes OD/OG
                                </mat-checkbox>
                            </div>
                        </mat-card-content>
                    </mat-card>

                    <!-- Nomenclature banner removed -->


                    <div class="eyes-container">
                        <!-- OD Selection -->
                        <mat-card class="eye-card od-card" formGroupName="od">
                            <div class="eye-header">
                                <span class="eye-badge">OD</span>
                                <h3>Lentille Droite</h3>
                                <button type="button" class="btn-stock-search-mini" (click)="openStockSearch('od')"
                                    *ngIf="isEditMode">
                                    <mat-icon>inventory_2</mat-icon> Stock
                                </button>
                            </div>
                            <mat-card-content>
                                <div class="grid-2">
                                    <mat-form-field appearance="outline">
                                        <mat-label>Marque</mat-label>
                                        <input matInput formControlName="marque" placeholder="Ex: Acuvue">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline">
                                        <mat-label>Modèle</mat-label>
                                        <input matInput formControlName="modele" placeholder="Ex: Oasys">
                                    </mat-form-field>
                                </div>
                                <div class="grid-3">
                                    <mat-form-field appearance="outline">
                                        <mat-label>Rayon (BC)</mat-label>
                                        <input matInput formControlName="rayon" placeholder="8.4">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline">
                                        <mat-label>Diamètre (DIA)</mat-label>
                                        <input matInput formControlName="diametre" placeholder="14.0">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>AC.VIS</mat-label>
                                        <input matInput formControlName="acuiteVisuelle" placeholder="10/10">
                                    </mat-form-field>
                                </div>

                                <div class="grid-4">
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Sphère</mat-label>
                                        <input matInput formControlName="sphere" placeholder="+0.00">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Cylindre</mat-label>
                                        <input matInput formControlName="cylindre" placeholder="-0.00">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Axe</mat-label>
                                        <input matInput formControlName="axe" placeholder="0°">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Addition</mat-label>
                                        <input matInput formControlName="addition" placeholder="+0.00">
                                    </mat-form-field>
                                </div>

                                <mat-divider class="my-3"></mat-divider>
                                <p class="section-subtitle">Adaptation & Kératométrie</p>

                                <div class="grid-2">
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Mouvement</mat-label>
                                        <mat-select formControlName="mouvement">
                                            <mat-option value="normal">Normal</mat-option>
                                            <mat-option value="excessif">Excessif</mat-option>
                                            <mat-option value="insuffisant">Insuffisant</mat-option>
                                        </mat-select>
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Centrage</mat-label>
                                        <mat-select formControlName="centrage">
                                            <mat-option value="bon">Bon</mat-option>
                                            <mat-option value="decentre">Décentré</mat-option>
                                            <mat-option value="bas">Bas</mat-option>
                                            <mat-option value="haut">Haut</mat-option>
                                        </mat-select>
                                    </mat-form-field>
                                </div>

                                <div class="grid-4 mt-2">
                                    <mat-form-field appearance="outline" class="dense-field highlight-field">
                                        <mat-label>H (K1)</mat-label>
                                        <input matInput formControlName="keratoH" placeholder="7.80">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field highlight-field">
                                        <mat-label>V (K2)</mat-label>
                                        <input matInput formControlName="keratoV" placeholder="7.90">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field highlight-field">
                                        <mat-label>Axe</mat-label>
                                        <input matInput formControlName="keratoAxe" placeholder="0">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field highlight-field">
                                        <mat-label>K.Moy</mat-label>
                                        <input matInput formControlName="keratoMoy" placeholder="7.85">
                                    </mat-form-field>
                                </div>
                            </mat-card-content>
                        </mat-card>

                        <!-- OG Selection (Conditional or Duplicate) -->
                        <mat-card class="eye-card og-card" formGroupName="og" *ngIf="diffLentilles">
                            <div class="eye-header">
                                <span class="eye-badge">OG</span>
                                <h3>Lentille Gauche</h3>
                                <button type="button" class="btn-stock-search-mini" (click)="openStockSearch('og')"
                                    *ngIf="isEditMode">
                                    <mat-icon>inventory_2</mat-icon> Stock
                                </button>
                            </div>
                            <mat-card-content>
                                <div class="grid-2">
                                    <mat-form-field appearance="outline">
                                        <mat-label>Marque</mat-label>
                                        <input matInput formControlName="marque" placeholder="Ex: Acuvue">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline">
                                        <mat-label>Modèle</mat-label>
                                        <input matInput formControlName="modele" placeholder="Ex: Oasys">
                                    </mat-form-field>
                                </div>
                                <div class="grid-3">
                                    <mat-form-field appearance="outline">
                                        <mat-label>Rayon (BC)</mat-label>
                                        <input matInput formControlName="rayon" placeholder="8.4">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline">
                                        <mat-label>Diamètre (DIA)</mat-label>
                                        <input matInput formControlName="diametre" placeholder="14.0">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>AC.VIS</mat-label>
                                        <input matInput formControlName="acuiteVisuelle" placeholder="10/10">
                                    </mat-form-field>
                                </div>

                                <div class="grid-4">
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Sphère</mat-label>
                                        <input matInput formControlName="sphere" placeholder="+0.00">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Cylindre</mat-label>
                                        <input matInput formControlName="cylindre" placeholder="-0.00">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Axe</mat-label>
                                        <input matInput formControlName="axe" placeholder="0°">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Addition</mat-label>
                                        <input matInput formControlName="addition" placeholder="+0.00">
                                    </mat-form-field>
                                </div>

                                <mat-divider class="my-3"></mat-divider>
                                <p class="section-subtitle">Adaptation & Kératométrie</p>

                                <div class="grid-2">
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Mouvement</mat-label>
                                        <mat-select formControlName="mouvement">
                                            <mat-option value="normal">Normal</mat-option>
                                            <mat-option value="excessif">Excessif</mat-option>
                                            <mat-option value="insuffisant">Insuffisant</mat-option>
                                        </mat-select>
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field">
                                        <mat-label>Centrage</mat-label>
                                        <mat-select formControlName="centrage">
                                            <mat-option value="bon">Bon</mat-option>
                                            <mat-option value="decentre">Décentré</mat-option>
                                            <mat-option value="bas">Bas</mat-option>
                                            <mat-option value="haut">Haut</mat-option>
                                        </mat-select>
                                    </mat-form-field>
                                </div>

                                <div class="grid-4 mt-2">
                                    <mat-form-field appearance="outline" class="dense-field highlight-field">
                                        <mat-label>H (K1)</mat-label>
                                        <input matInput formControlName="keratoH" placeholder="7.80">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field highlight-field">
                                        <mat-label>V (K2)</mat-label>
                                        <input matInput formControlName="keratoV" placeholder="7.90">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field highlight-field">
                                        <mat-label>Axe</mat-label>
                                        <input matInput formControlName="keratoAxe" placeholder="0">
                                    </mat-form-field>
                                    <mat-form-field appearance="outline" class="dense-field highlight-field">
                                        <mat-label>K.Moy</mat-label>
                                        <input matInput formControlName="keratoMoy" placeholder="7.85">
                                    </mat-form-field>
                                </div>
                            </mat-card-content>
                        </mat-card>

                        <!-- Placeholder if same lenses -->
                        <div class="eye-card og-card opacity-50" *ngIf="!diffLentilles">
                            <div class="eye-header">
                                <span class="eye-badge">OG</span>
                                <h3>Lentille Gauche</h3>
                            </div>
                            <mat-card-content class="flex-center">
                                <p class="text-muted">Identique à l'œil droit</p>
                            </mat-card-content>
                        </div>
                    </div>
                </div>
            </mat-tab>


            <!-- ONGLET 3: ADAPTATION MODERNE (NOUVEAU) -->
            <mat-tab>
                <ng-template mat-tab-label>
                    <mat-icon class="tab-icon">auto_awesome</mat-icon>
                    Adaptation Moderne
                </ng-template>


                <app-adaptation-moderne [formGroup]="$any(ficheForm.get('adaptation'))"
                    (suggestionGenerated)="onSuggestionGenerated($event)">
                </app-adaptation-moderne>
            </mat-tab>


            <!-- ONGLET 4: ADAPTATION (ANCIEN) -->
            <mat-tab>
                <ng-template mat-tab-label>
                    <mat-icon class="tab-icon">fact_check</mat-icon>
                    Adaptation
                </ng-template>

                <div class="tab-content adaptation-compact" formGroupName="adaptation">

                    <!-- Dates Section Only -->
                    <mat-card class="dates-card">
                        <div class="card-header">
                            <h3>Dates de Suivi</h3>
                        </div>
                        <mat-card-content>
                            <div class="dates-grid">
                                <mat-form-field appearance="outline">
                                    <mat-label>Date de Pose</mat-label>
                                    <input matInput [matDatepicker]="pickerEssai" formControlName="dateEssai">
                                    <mat-datepicker-toggle matIconSuffix [for]="pickerEssai"></mat-datepicker-toggle>
                                    <mat-datepicker #pickerEssai></mat-datepicker>
                                </mat-form-field>
                                <mat-form-field appearance="outline">
                                    <mat-label>Date de Contrôle</mat-label>
                                    <input matInput [matDatepicker]="pickerControleFinal"
                                        formControlName="dateControle">
                                    <mat-datepicker-toggle matIconSuffix
                                        [for]="pickerControleFinal"></mat-datepicker-toggle>
                                    <mat-datepicker #pickerControleFinal></mat-datepicker>
                                </mat-form-field>
                            </div>
                        </mat-card-content>
                    </mat-card>

                    <!-- Clinical Comparison Grid -->
                    <div class="comparison-grid-card">
                        <!-- Grid Header -->
                        <div class="grid-header">
                            <div class="col-label">Paramètre</div>
                            <div class="col-eye od-col">
                                <span class="eye-badge-mini od-bg">OD</span> Œil Droit
                            </div>
                            <div class="col-eye og-col">
                                <span class="eye-badge-mini og-bg">OG</span> Œil Gauche
                            </div>
                        </div>

                        <div class="grid-body">
                            <!-- Row: Fréquence Cillement -->
                            <div class="grid-row">
                                <div class="row-label">Fréquence Cillement</div>
                                <div class="row-control" formGroupName="od">
                                    <mat-button-toggle-group formControlName="frequenceCillement"
                                        class="symmetric-toggle">
                                        <mat-button-toggle value="lent">Lent</mat-button-toggle>
                                        <mat-button-toggle value="normal">Normal</mat-button-toggle>
                                        <mat-button-toggle value="frequent">Fréquent</mat-button-toggle>
                                    </mat-button-toggle-group>
                                </div>
                                <div class="row-control" formGroupName="og">
                                    <mat-button-toggle-group formControlName="frequenceCillement"
                                        class="symmetric-toggle">
                                        <mat-button-toggle value="lent">Lent</mat-button-toggle>
                                        <mat-button-toggle value="normal">Normal</mat-button-toggle>
                                        <mat-button-toggle value="frequent">Fréquent</mat-button-toggle>
                                    </mat-button-toggle-group>
                                </div>
                            </div>

                            <!-- Row: Amplitude Cillement -->
                            <div class="grid-row">
                                <div class="row-label">Amplitude Cillement</div>
                                <div class="row-control" formGroupName="od">
                                    <mat-button-toggle-group formControlName="amplitudeCillement"
                                        class="symmetric-toggle">
                                        <mat-button-toggle value="complet">Complet</mat-button-toggle>
                                        <mat-button-toggle value="incomplet">Incomplet</mat-button-toggle>
                                    </mat-button-toggle-group>
                                </div>
                                <div class="row-control" formGroupName="og">
                                    <mat-button-toggle-group formControlName="amplitudeCillement"
                                        class="symmetric-toggle">
                                        <mat-button-toggle value="complet">Complet</mat-button-toggle>
                                        <mat-button-toggle value="incomplet">Incomplet</mat-button-toggle>
                                    </mat-button-toggle-group>
                                </div>
                            </div>

                            <!-- Row: Tonus Palpébral -->
                            <div class="grid-row">
                                <div class="row-label">Tonus Palpébral</div>
                                <div class="row-control" formGroupName="od">
                                    <mat-button-toggle-group formControlName="tonusPalpebral" class="symmetric-toggle">
                                        <mat-button-toggle value="fort">Fort</mat-button-toggle>
                                        <mat-button-toggle value="normal">Normal</mat-button-toggle>
                                        <mat-button-toggle value="faible">Faible</mat-button-toggle>
                                    </mat-button-toggle-group>
                                </div>
                                <div class="row-control" formGroupName="og">
                                    <mat-button-toggle-group formControlName="tonusPalpebral" class="symmetric-toggle">
                                        <mat-button-toggle value="fort">Fort</mat-button-toggle>
                                        <mat-button-toggle value="normal">Normal</mat-button-toggle>
                                        <mat-button-toggle value="faible">Faible</mat-button-toggle>
                                    </mat-button-toggle-group>
                                </div>
                            </div>

                            <!-- Row: Réaction Pupillaire -->
                            <div class="grid-row">
                                <div class="row-label">Réaction Pupillaire</div>
                                <div class="row-control" formGroupName="od">
                                    <mat-button-toggle-group formControlName="reactionPupillaire"
                                        class="symmetric-toggle">
                                        <mat-button-toggle value="rapide">Rapide</mat-button-toggle>
                                        <mat-button-toggle value="normale">Normale</mat-button-toggle>
                                        <mat-button-toggle value="lente">Lente</mat-button-toggle>
                                    </mat-button-toggle-group>
                                </div>
                                <div class="row-control" formGroupName="og">
                                    <mat-button-toggle-group formControlName="reactionPupillaire"
                                        class="symmetric-toggle">
                                        <mat-button-toggle value="rapide">Rapide</mat-button-toggle>
                                        <mat-button-toggle value="normale">Normale</mat-button-toggle>
                                        <mat-button-toggle value="lente">Lente</mat-button-toggle>
                                    </mat-button-toggle-group>
                                </div>
                            </div>

                            <!-- Row: Sécrétion -->
                            <div class="grid-row">
                                <div class="row-label">Sécrétion Lacrymale</div>
                                <div class="row-control" formGroupName="od">
                                    <mat-form-field appearance="outline" class="measure-input">
                                        <input matInput type="number" formControlName="secretionLacrimale"
                                            placeholder="0.00">
                                        <span matTextSuffix>mm</span>
                                    </mat-form-field>
                                </div>
                                <div class="row-control" formGroupName="og">
                                    <mat-form-field appearance="outline" class="measure-input">
                                        <input matInput type="number" formControlName="secretionLacrimale"
                                            placeholder="0.00">
                                        <span matTextSuffix>mm</span>
                                    </mat-form-field>
                                </div>
                            </div>

                            <!-- Row: B.U.T -->
                            <div class="grid-row">
                                <div class="row-label">B.U.T</div>
                                <div class="row-control" formGroupName="od">
                                    <mat-form-field appearance="outline" class="measure-input">
                                        <input matInput type="number" formControlName="but" placeholder="0">
                                        <span matTextSuffix>sec</span>
                                    </mat-form-field>
                                </div>
                                <div class="row-control" formGroupName="og">
                                    <mat-form-field appearance="outline" class="measure-input">
                                        <input matInput type="number" formControlName="but" placeholder="0">
                                        <span matTextSuffix>sec</span>
                                    </mat-form-field>
                                </div>
                            </div>

                            <!-- Row: État Paupières -->
                            <div class="grid-row border-none">
                                <div class="row-label">État Paupières</div>
                                <div class="row-control" formGroupName="od">
                                    <mat-form-field appearance="outline" class="text-input">
                                        <input matInput formControlName="etatPaupieres" placeholder="Observations...">
                                    </mat-form-field>
                                </div>
                                <div class="row-control" formGroupName="og">
                                    <mat-form-field appearance="outline" class="text-input">
                                        <input matInput formControlName="etatPaupieres" placeholder="Observations...">
                                    </mat-form-field>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Remarques & Validation (Footer) -->
                    <div class="footer-section">
                        <mat-form-field appearance="outline" class="remarques-field">
                            <mat-label>Remarques Globales</mat-label>
                            <textarea matInput formControlName="remarques" rows="2"></textarea>
                        </mat-form-field>
                    </div>

                </div>
            </mat-tab>
            <!-- ONGLET 5: FACTURATION -->
            <mat-tab>
                <ng-template mat-tab-label>
                    <mat-icon class="tab-icon">euro</mat-icon>
                    Facturation
                </ng-template>
                <div class="tab-content" style="padding: 24px;">
                    <!-- Always render so @ViewChild is available, but hide if not active -->
                    <app-facture-form [class.hidden]="activeTab !== 4" [factureId]="linkedFacture?.id" [embedded]="true"
                        [isReadonly]="!isEditMode"
                        (onSaved)="onInvoiceSaved($event)" [nomenclature]="nomenclatureString"
                        [initialLines]="initialInvoiceLines" [clientIdInput]="clientId" [ficheIdInput]="ficheId">
                    </app-facture-form>
                </div>
            </mat-tab>

            <!-- ONGLET 6: PAIEMENTS -->
            <mat-tab>
                <ng-template mat-tab-label>
                    <mat-icon class="tab-icon">payments</mat-icon>
                    Paiements
                </ng-template>
                <div class="tab-content" style="padding: 24px;">
                    <!-- Always render for consistency, hide if not active -->
                    <app-payment-list [class.hidden]="activeTab !== 5" [clientId]="clientId" [ficheId]="ficheId"
                        [clientName]="clientDisplayName" [clientCin]="clientCinValue"
                        (paymentAdded)="onPaymentAdded()"></app-payment-list>
                </div>
            </mat-tab>

            <!-- ONGLET 7: SUIVI COMMANDE -->
            <mat-tab>
                <ng-template mat-tab-label>
                    <mat-icon class="tab-icon">local_shipping</mat-icon>
                    Suivi Commande
                </ng-template>

                <div class="tab-content" *ngIf="activeTab === 6">
                    <!-- Error message if form group is missing -->
                    <div *ngIf="!ficheForm.get('suiviCommande')"
                        class="p-8 text-center bg-white rounded-xl shadow-sm border border-red-100">
                        <mat-icon class="text-red-500 text-6xl mb-4">error</mat-icon>
                        <h3 class="text-xl font-bold text-red-700 mb-2">Erreur de configuration</h3>
                        <p class="text-gray-600">Le formulaire de suivi de commande n'est pas initialisé.</p>
                    </div>

                    <div *ngIf="ficheForm.get('suiviCommande')" formGroupName="suiviCommande">
                        <!-- Modern Header -->
                        <div class="tab-header border-b-0 pb-0">
                            <div class="icon-box-purple shadow-md">
                                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                                    <path
                                        d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" />
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-xl font-black text-gray-800 tracking-tight">Suivi de Commande Lentilles</h3>
                                <p class="text-gray-500 text-sm font-medium">Gérer le statut de commande auprès du fournisseur</p>
                            </div>
                        </div>

                        <!-- Beautiful Stepper UI -->
                        <div class="mb-10 px-8 mt-6">
                            <div class="relative flex items-center justify-between w-full">
                                <!-- Base gray line -->
                                <div class="absolute left-0 top-1/2 transform -translate-y-1/2 w-full h-1.5 bg-gray-200 rounded-full -z-10"></div>
                                <!-- Active colored progress line -->
                                <div class="absolute left-0 top-1/2 transform -translate-y-1/2 h-1.5 bg-blue-500 rounded-full -z-10 transition-all duration-500 ease-in-out"
                                    [style.width]="getProgressBarWidth()"></div>

                                <!-- Step 1: A Commander -->
                                <div class="flex flex-col items-center bg-white px-4 relative z-10 cursor-pointer group"
                                    (click)="setOrderStatus('A_COMMANDER')">
                                    <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-lg mb-2 shadow transition-all duration-300 transform group-hover:scale-110"
                                        [ngClass]="getStepClass('A_COMMANDER')">
                                        <mat-icon *ngIf="getStepState('A_COMMANDER') === 'completed'" class="text-white">check</mat-icon>
                                        <span *ngIf="getStepState('A_COMMANDER') !== 'completed'" [ngClass]="getStepTextClass('A_COMMANDER')">1</span>
                                    </div>
                                    <span class="text-sm font-bold whitespace-nowrap transition-colors duration-300"
                                        [ngClass]="getTextClass('A_COMMANDER')">À Commander</span>
                                </div>

                                <!-- Step 2: Commandé -->
                                <div class="flex flex-col items-center bg-white px-4 relative z-10 cursor-pointer group"
                                    (click)="setOrderStatus('COMMANDE')">
                                    <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-lg mb-2 shadow transition-all duration-300 transform group-hover:scale-110"
                                        [ngClass]="getStepClass('COMMANDE')">
                                        <mat-icon *ngIf="getStepState('COMMANDE') === 'completed'" class="text-white">check</mat-icon>
                                        <span *ngIf="getStepState('COMMANDE') !== 'completed'" [ngClass]="getStepTextClass('COMMANDE')">2</span>
                                    </div>
                                    <span class="text-sm font-bold whitespace-nowrap transition-colors duration-300"
                                        [ngClass]="getTextClass('COMMANDE')">Commandé</span>
                                </div>

                                <!-- Step 3: Reçu -->
                                <div class="flex flex-col items-center bg-white px-4 relative z-10 cursor-pointer group"
                                    (click)="setOrderStatus('RECU')">
                                    <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-lg mb-2 shadow transition-all duration-300 transform group-hover:scale-110"
                                        [ngClass]="getStepClass('RECU')">
                                        <mat-icon *ngIf="getStepState('RECU') === 'completed'" class="text-white">check</mat-icon>
                                        <span *ngIf="getStepState('RECU') !== 'completed'" [ngClass]="getStepTextClass('RECU')">3</span>
                                    </div>
                                    <span class="text-sm font-bold whitespace-nowrap transition-colors duration-300"
                                        [ngClass]="getTextClass('RECU')">Reçu</span>
                                </div>

                                <!-- Step 4: Livré Client -->
                                <div class="flex flex-col items-center bg-white px-4 relative z-10 cursor-pointer group"
                                    (click)="setOrderStatus('LIVRE_CLIENT')">
                                    <div class="w-12 h-12 rounded-full flex items-center justify-center font-bold text-lg mb-2 shadow transition-all duration-300 transform group-hover:scale-110"
                                        [ngClass]="getStepClass('LIVRE_CLIENT')">
                                        <mat-icon *ngIf="getStepState('LIVRE_CLIENT') === 'completed'" class="text-white">check</mat-icon>
                                        <span *ngIf="getStepState('LIVRE_CLIENT') !== 'completed'" [ngClass]="getStepTextClass('LIVRE_CLIENT')">4</span>
                                    </div>
                                    <span class="text-sm font-bold whitespace-nowrap transition-colors duration-300"
                                        [ngClass]="getTextClass('LIVRE_CLIENT')">Livré Client</span>
                                </div>
                            </div>
                        </div>

                        <!-- Action Area -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                            <!-- Left: Status & Actions -->
                            <div class="space-y-6">
                                <!-- Dynamic Action Button instead of Static Badge -->
                                <div class="section-card flex flex-col items-center justify-center p-8 bg-gradient-to-br from-white to-blue-50/30 border border-blue-100 relative overflow-hidden shadow-sm hover:shadow-md transition-all rounded-2xl">
                                    <div class="absolute top-0 left-0 w-full h-1 bg-blue-500"></div>

                                    <h4 class="text-gray-400 uppercase text-xs font-bold tracking-widest mb-5">Prochaine Étape</h4>

                                    <button type="button"
                                        class="w-full max-w-xs py-3 text-base font-bold flex items-center justify-center gap-3 rounded-xl disabled:opacity-50 disabled:cursor-not-allowed transition-all shadow-sm"
                                        [ngClass]="suiviStatut === 'RECU' ? 'btn-success' : 'btn-primary'"
                                        (click)="advanceOrderStatus()" [disabled]="suiviStatut === 'LIVRE_CLIENT'">
                                        <mat-icon>{{ getNextStatusIcon() }}</mat-icon>
                                        <span>{{ getNextStatusText() }}</span>
                                    </button>

                                    <div class="mt-6 flex items-center gap-2 bg-white px-4 py-2 rounded-full border border-gray-100 shadow-sm">
                                        <span class="text-xs font-medium text-gray-500">Statut actuel:</span>
                                        <strong class="text-sm" [ngClass]="getTextClass(suiviStatut)">{{ getNextStatusText(true) }}</strong>
                                    </div>
                                </div>

                                <!-- Gestion de la Casse (Stroked) -->
                                <div class="bg-white border-2 border-red-100 rounded-2xl p-6 relative overflow-hidden">
                                    <div class="absolute top-0 left-0 w-1 h-full bg-red-500"></div>
                                    <div class="flex justify-between items-center mb-4 pl-2">
                                        <h4 class="text-red-600 flex items-center font-bold text-lg m-0">
                                            <mat-icon class="mr-2">broken_image</mat-icon> Gestion de la Casse
                                        </h4>
                                    </div>
                                    <p class="text-sm text-gray-500 mb-6 leading-relaxed pl-2">
                                        En cas de casse, déclarez-la ici pour réinitialiser la commande et garder une trace de l'historique.
                                    </p>
                                    <button type="button"
                                        class="w-full py-3 bg-white text-red-600 border-2 border-red-500 rounded-xl font-bold hover:bg-red-50 hover:text-red-700 transition-colors flex items-center justify-center shadow-sm disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:bg-white"
                                        (click)="reportCasse()">
                                        <mat-icon class="mr-2">warning</mat-icon> DÉCLARER UNE CASSE
                                    </button>
                                </div>
                            </div>

                            <!-- Right: Details Form -->
                            <div class="section-card bg-white shadow-sm flex flex-col rounded-2xl border border-gray-100 p-6 min-h-[400px]">
                                <div class="flex justify-between items-start border-b border-gray-100 pb-4 mb-6">
                                    <h4 class="text-gray-800 font-bold flex items-center gap-2 text-lg m-0">
                                        <mat-icon class="text-gray-400">receipt_long</mat-icon> Détails Commande
                                    </h4>
                                    <div class="flex gap-2 no-print">
                                        <button type="button" class="btn-print-secondary" (click)="printFicheTechnique()" matTooltip="Imprimer la fiche technique">
                                            <mat-icon>assignment_turned_in</mat-icon> <span class="hidden sm:inline">Fiche Technique</span>
                                        </button>
                                        <button type="button" class="btn-print-secondary" (click)="printBC()" matTooltip="Imprimer le bon de commande">
                                            <mat-icon>print</mat-icon> <span class="hidden sm:inline">Imprimer BC</span>
                                        </button>
                                        <button type="button" class="btn-email-stylish" (click)="emailOrder()" [disabled]="loading" matTooltip="Envoyer par email au fournisseur">
                                            <mat-icon>{{ loading ? 'hourglass_empty' : 'send' }}</mat-icon> <span class="hidden sm:inline">Envoyer Email</span>
                                        </button>
                                    </div>
                                </div>

                                <div class="grid grid-cols-1 gap-5 flex-grow">
                                    <!-- Fournisseur Lentilles -->
                                    <div class="flex flex-col">
                                        <label class="font-bold text-gray-700 flex items-center gap-2 mb-1.5 text-sm">
                                            <mat-icon class="text-gray-400 text-sm w-4 h-4 mr-1">storefront</mat-icon> Fournisseur Lentilles
                                        </label>
                                        <input type="text" [formControl]="fournisseurCtrl" placeholder="Sélectionner ou saisir un fournisseur" [matAutocomplete]="autoSuppliers"
                                            class="w-full min-w-0 box-border px-4 py-2.5 rounded-xl border border-gray-200 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-all text-sm text-gray-700 font-medium placeholder-gray-400 shadow-sm">
                                        <mat-autocomplete #autoSuppliers="matAutocomplete" [displayWith]="displaySupplierFn">
                                            <mat-option *ngFor="let supplier of filteredSuppliers$ | async" [value]="supplier">
                                                {{ supplier.nom }}
                                            </mat-option>
                                        </mat-autocomplete>
                                    </div>

                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                                        <!-- Réf. Fournisseur / Commande -->
                                        <div class="flex flex-col">
                                            <label class="font-bold text-gray-700 flex items-center gap-2 mb-1.5 text-sm">
                                                <mat-icon class="text-gray-400 text-sm w-4 h-4 mr-1">tag</mat-icon> Réf. Fournisseur / Commande
                                            </label>
                                            <input type="text" formControlName="referenceCommande" placeholder="Ex: CMD-12345"
                                                class="w-full min-w-0 box-border px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50/50 hover:border-blue-400 hover:bg-white focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-all text-sm text-gray-700 font-medium placeholder-gray-400">
                                        </div>
                                        <!-- N° Suivi / BL -->
                                        <div class="flex flex-col">
                                            <label class="font-bold text-gray-700 flex items-center gap-2 mb-1.5 text-sm">
                                                <mat-icon class="text-gray-400 text-sm w-4 h-4 mr-1">local_shipping</mat-icon> N° Suivi / BL
                                            </label>
                                            <input type="text" formControlName="trackingNumber" placeholder="Ex: TRK-98765"
                                                class="w-full min-w-0 box-border px-4 py-2.5 rounded-xl border border-gray-200 bg-gray-50/50 hover:border-blue-400 hover:bg-white focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-all text-sm text-gray-700 font-medium placeholder-gray-400">
                                        </div>
                                    </div>

                                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
                                        <!-- Date de Commande -->
                                        <div class="flex flex-col">
                                            <label class="font-bold text-gray-700 flex items-center gap-2 mb-1.5 text-sm">
                                                <mat-icon class="text-gray-400 text-sm w-4 h-4 mr-1">calendar_today</mat-icon> Date de Commande
                                            </label>
                                            <div class="relative">
                                                <input type="date" formControlName="dateCommande"
                                                    title="Date de Commande" placeholder="JJ/MM/AAAA"
                                                    class="w-full min-w-0 box-border px-4 py-2.5 pr-10 rounded-xl border border-gray-200 bg-gray-50/50 hover:border-blue-400 hover:bg-white focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-all text-sm text-gray-700 font-medium h-[44px]">
                                                <mat-icon class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-lg">calendar_today</mat-icon>
                                            </div>
                                        </div>
                                        <!-- Date de Réception -->
                                        <div class="flex flex-col">
                                            <label class="font-bold text-gray-700 flex items-center gap-2 mb-1.5 text-sm">
                                                <mat-icon class="text-gray-400 text-sm w-4 h-4 mr-1">calendar_today</mat-icon> Date de Réception
                                            </label>
                                            <div class="relative">
                                                <input type="date" formControlName="dateReception"
                                                    title="Date de Réception" placeholder="JJ/MM/AAAA"
                                                    class="w-full min-w-0 box-border px-4 py-2.5 pr-10 rounded-xl border border-gray-200 bg-gray-50/50 hover:border-blue-400 hover:bg-white focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-all text-sm text-gray-700 font-medium h-[44px]">
                                                <mat-icon class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 pointer-events-none text-lg">calendar_today</mat-icon>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Notes / Historique Manuel -->
                                    <div class="flex flex-col mt-auto mb-0 bg-gray-50/50 rounded-xl p-4 border border-gray-200">
                                        <label class="font-bold text-gray-700 flex items-center gap-2 mb-3 text-sm">
                                            <mat-icon class="text-gray-400 text-sm w-4 h-4 mr-1">notes</mat-icon> Notes / Historique Manuel
                                        </label>
                                        <textarea formControlName="commentaire" rows="3"
                                            placeholder="Ajouter une note importante sur cette commande..."
                                            class="w-full min-w-0 box-border px-4 py-3 rounded-lg border border-gray-200 bg-white hover:border-blue-400 focus:outline-none focus:ring-2 focus:ring-blue-100 focus:border-blue-500 transition-all text-sm text-gray-700 font-medium placeholder-gray-400 resize-none"></textarea>
                                    </div>

                                    <!-- Auto-generated Timeline -->
                                    <div class="bg-gray-50 border border-gray-100 rounded-xl p-5 mt-2"
                                        *ngIf="getTimelineEvents().length > 0">
                                        <h5 class="text-[10px] uppercase font-bold text-gray-400 tracking-wider mb-4">Journal Automatique</h5>
                                        <!-- Wrapper to handle scrolling without clipping absolute dots -->
                                        <div class="overflow-y-auto custom-scrollbar pr-2 grow" style="max-height: 400px;">
                                            <div class="relative border-l-2 border-gray-200 ml-10 space-y-5 py-2">
                                                <div class="relative pl-7 pb-2" *ngFor="let event of getTimelineEvents()">
                                                    <div class="absolute w-3.5 h-3.5 rounded-full -left-[9px] top-0.5 border-2 border-white z-10"
                                                        [ngClass]="getTimelineDotClass(event.type)"></div>
                                                    <div class="text-[10px] text-gray-400 font-bold uppercase tracking-wider mb-0.5">{{ event.date | date:'dd MMM yyyy à HH:mm' }}</div>
                                                    <div class="text-sm font-medium text-gray-800">{{ event.description }}</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </mat-tab>
        </mat-tab-group>

            <!-- Badges positioned at right end of tab bar -->
            <div class="tab-bar-badges">
                <div class="fiche-badge" *ngIf="ficheId && ficheId !== 'new' && currentFiche?.numero">
                    <mat-icon>assignment</mat-icon>
                    <div class="badge-content">
                        <span class="badge-label">Fiche N°</span>
                        <span class="badge-value">{{ currentFiche.numero }}</span>
                    </div>
                </div>
                <div class="vendeur-badge" *ngIf="currentUser$ | async as user">
                    <mat-icon>person</mat-icon>
                    <div class="badge-content">
                        <span class="badge-label">Vendeur / Opticien</span>
                        <span class="badge-value">{{ user.first_name }} {{ user.last_name }}</span>
                    </div>
                </div>
            </div>
        </div>
    </form>


    <!-- File Viewer Modal -->
    <div class="file-viewer-overlay" *ngIf="viewingFile" (click)="closeViewer()">
        <div class="file-viewer-content" (click)="$event.stopPropagation()">
            <div class="viewer-header">
                <h3>{{ viewingFile.name }}</h3>
                <button mat-icon-button (click)="closeViewer()">
                    <mat-icon>close</mat-icon>
                </button>
            </div>
            <div class="viewer-body">
                <img *ngIf="viewingFile.type.startsWith('image/')" [src]="viewingFile.preview" class="preview-image">
                <iframe *ngIf="viewingFile.type === 'application/pdf'" [src]="viewingFile.preview"
                    class="preview-pdf"></iframe>
            </div>
        </div>
    </div>

    <!-- UNIFIED PRINT LAYOUT (Lentilles Sheet) -->
    <div class="print-only">
        <div class="print-container">
            <header>
                <div class="logo-area">
                    <img *ngIf="companySettings?.logoUrl" [src]="companySettings.logoUrl" alt="Logo" class="establishment-logo">
                    <div *ngIf="!companySettings?.logoUrl" class="placeholder-logo">
                        <span class="text-xl font-bold">OPTISSAS</span>
                    </div>
                </div>
                <div class="sheet-title">
                    <h1>Fiche Technique Lentilles</h1>
                    <p>Fiche N° {{ currentFiche?.numero || '-' }}</p>
                </div>
            </header>

            <div class="client-section">
                <div class="client-info-print">
                    <h4>Informations Client</h4>
                    <p><strong>Nom:</strong> {{ clientDisplayName }}</p>
                    <p><strong>Tél:</strong> {{ client?.telephone }}</p>
                </div>
                <div class="client-info-print text-right">
                    <h4>Prescription</h4>
                    <p><strong>Date:</strong> {{ ficheForm.get('ordonnance.datePrescription')?.value | date:'dd/MM/yyyy' }}</p>
                    <p><strong>Prescripteur:</strong> {{ ficheForm.get('ordonnance.prescripteur')?.value || 'Non précisé' }}</p>
                </div>
            </div>

            <div class="technical-section">
                <div class="section-header">Caractéristiques Lentilles</div>
                <table class="specs-table">
                    <thead>
                        <tr>
                            <th>Oeil</th>
                            <th>Sphere</th>
                            <th>Cylindre</th>
                            <th>Axe</th>
                            <th>Addition</th>
                            <th>Marque / Modèle</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>OD</td>
                            <td>{{ ficheForm.get('lentilles.od.sphere')?.value || '-' }}</td>
                            <td>{{ ficheForm.get('lentilles.od.cylindre')?.value || '-' }}</td>
                            <td>{{ ficheForm.get('lentilles.od.axe')?.value || '-' }}</td>
                            <td>{{ ficheForm.get('lentilles.od.addition')?.value || '-' }}</td>
                            <td>{{ ficheForm.get('lentilles.od.marque')?.value }} {{ ficheForm.get('lentilles.od.modele')?.value }}</td>
                        </tr>
                        <tr>
                            <td>OG</td>
                            <td>{{ ficheForm.get('lentilles.og.sphere')?.value || '-' }}</td>
                            <td>{{ ficheForm.get('lentilles.og.cylindre')?.value || '-' }}</td>
                            <td>{{ ficheForm.get('lentilles.og.axe')?.value || '-' }}</td>
                            <td>{{ ficheForm.get('lentilles.og.addition')?.value || '-' }}</td>
                            <td>{{ ficheForm.get('lentilles.og.marque')?.value }} {{ ficheForm.get('lentilles.og.modele')?.value }}</td>
                        </tr>
                    </tbody>
                </table>
            </div>

            <div class="suivi-section" *ngIf="ficheForm.get('suiviCommande')">
                <h4>Suivi Commande</h4>
                <div class="suivi-grid">
                    <div><strong>Fournisseur:</strong> {{ ficheForm.get('suiviCommande.fournisseur')?.value }}</div>
                    <div><strong>Réf Commande:</strong> {{ ficheForm.get('suiviCommande.referenceCommande')?.value }}</div>
                    <div><strong>Statut:</strong> {{ ficheForm.get('suiviCommande.statut')?.value }}</div>
                </div>
            </div>

            <div class="print-footer">
                <div class="signature-box">Signature Opticien</div>
                <div class="signature-box">Signature Client</div>
        </div>
    </div>
</div>
