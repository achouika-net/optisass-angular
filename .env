# ================================================================
# OPTISAAS - Environnement de développement local (Docker)
# ================================================================

NODE_ENV=development
PORT=3000

# Base de données (cohérent avec docker-compose.yml)
DATABASE_URL=postgresql://postgres:mypassword@db:5432/optisaas?schema=public

# JWT
JWT_SECRET=optisaas_dev_secret_change_in_production
JWT_EXPIRATION=24h

# MinIO (cohérent avec docker-compose.yml)
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=optisaas
MINIO_USE_SSL=false

# CORS (dev local)
CORS_ORIGIN=http://localhost:4200

# Upload
UPLOAD_DIR=./uploads

# Logs
LOG_LEVEL=debug
